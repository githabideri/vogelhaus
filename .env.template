# Vogelhaus Configuration Template
# Copy to .env and fill in your values:  cp .env.template .env

# === Network ===
PI4_LAN_IP=192.168.0.x
ZERO_LAN_IP=192.168.0.x
NAS_IP=192.168.0.x
WIFI_SSID_5G=your_5ghz_wifi
WIFI_SSID_2G=your_2ghz_wifi
TAILSCALE_PI4=100.x.x.x
TAILSCALE_ZERO=100.x.x.x

# === SSH ===
PI4_SSH_HOST=vogl
PI4_USER=vogl
ZERO_USER=vb-light

# === NAS ===
NAS_USER=your_nas_user
NAS_SHARE=your_nas_share
NAS_MOUNT=/mnt/nas

# === Storage ===
SSD_PATH=/srv/ssd
SSD_RECORDINGS=/srv/ssd/recordings

# === Streaming ===
TWITCH_CHANNEL=your_twitch_channel
RESTREAMER_USER=admin
RESTREAMER_PASS=changeme
RTSP_CAM=rtsp://127.0.0.1:8554/vogl-cam
RTSP_NOIR=rtsp://127.0.0.1:8554/vogl-noir

# === Web Status ===
STATUS_PORT=8088

# === Camera Automation ===
# Location for sunrise/sunset calculation (decimal degrees)
LOCATION_LAT=48.3069
LOCATION_LON=14.2858
# Switch cameras X minutes before sunrise/sunset
CAMERA_SWITCH_OFFSET_MIN=10
# Restreamer Docker container name
RESTREAMER_DOCKER=restreamer
# RTSP stream URLs (internal to Pi4, via Docker gateway)
PI4_STREAM=rtsp://172.20.0.1:8554/vogl-cam
NOIR_STREAM=rtsp://172.20.0.1:8554/vogl-noir
# Log directory
LOG_DIR=/var/log/vogelhaus

# === Dashboard ===
DASHBOARD_PORT=8088
DASHBOARD_API_TOKEN=changeme_generate_secure_token
STATUS_SCRIPT=/home/vogl/scripts/vogelhaus-local.sh
CAMERA_SWITCH_SCRIPT=/usr/local/bin/camera-switch.sh
REPORTS_DIR=/var/log/vogelhaus/reports
MEDIA_DIR=/tmp/vogelhaus-status
RESTREAMER_URL=http://localhost:8080
MEDIAMTX_HLS_PI4=http://localhost:8554/vogl-cam
MEDIAMTX_HLS_NOIR=http://localhost:8554/vogl-noir
